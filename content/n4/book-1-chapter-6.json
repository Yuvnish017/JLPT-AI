    "grammar": [
      {
        "pattern": "よてい／つごう／ばあい の違い",
        "meaning": "よてい (予定) = a fixed schedule or plan; つごう (都合) = personal convenience or circumstances (good/bad); ばあい (場合) = a hypothetical or specific case / situation",
        "example": "週末は何か予定がありますか。(Do you have any plans this weekend?) / あしたはちょっと都合が悪いです。(Tomorrow is a bit inconvenient for me.) / 雨の場合、試合はありません。(In the case of rain, the game will be cancelled.)"
      },
      {
        "pattern": "とまる — two different kanji, two different meanings",
        "meaning": "止まる = to stop (a vehicle, a machine); 泊まる = to stay overnight. Same sound, completely different meaning — context and kanji distinguish them.",
        "example": "バスが止まりました。(The bus stopped.) / ホテルに泊まります。(I will stay at a hotel.)"
      },
      {
        "pattern": "Adjective い → Adjective さ (noun form)",
        "meaning": "い-adjectives become nouns by replacing い with さ. Used when talking about a measurable quantity.",
        "example": "重い → 重さ (weight) / 高い → 高さ (height) / 長い → 長さ (length) / 大きい → 大きさ (size)"
      },
      {
        "pattern": "〜に比べると / 〜と比べて",
        "meaning": "Compared to ~; in comparison with ~",
        "example": "先週に比べると、今週はいそがしいです。(Compared to last week, this week is busier.)"
      },
      {
        "pattern": "尊敬語 (Honorific language) — おいでになる／ご覧になる／おっしゃる／召し上がる",
        "meaning": "Used to elevate the actions of the listener or a third party (superior). These replace the plain verb forms.",
        "example": "先生はもうおいでになりましたか。(Has the teacher already arrived?) / どうぞ召し上がってください。(Please go ahead and eat.) / 社長、田中様がおいでになりました。(President, Mr. Tanaka has arrived.)"
      },
      {
        "pattern": "謙譲語 (Humble language) — まいる／もうす／うかがう／はいけんする／いただく",
        "meaning": "Used to lower the speaker's own actions, showing respect to the listener. These replace the plain verb forms.",
        "example": "はじめまして、山田ともうします。(Nice to meet you, my name is Yamada.) / 先生からうかがいました。(I heard it from the teacher.) / しつれいします。きっぷをはいけんします。(Excuse me, I will look at the ticket.)"
      },
      {
        "pattern": "〜場合は / 〜場合に",
        "meaning": "In the case of ~; if ~ happens. Used for stating what to do in a specific situation.",
        "example": "おくれる場合は、知らせてください。(If you are going to be late, please let me know.) / 電車が止まった場合は、バスを使ってください。(In the case that trains stop, please use the bus.)"
      },
      {
        "pattern": "育てる (transitive) ⟺ 育つ (intransitive) / 沸かす (transitive) ⟺ 沸く (intransitive)",
        "meaning": "Week 6 continues the intransitive/transitive pair theme. 育てる = someone raises/grows something (を); 育つ = something grows on its own (が). 沸かす = to boil water (を); 沸く = water comes to a boil (が).",
        "example": "木を育てる。(We grow a tree.) / 木が育つ。(The tree grows.) / おゆを沸かす。(Boil the water.) / おゆが沸く。(The water boils.)"
      }
    ],
