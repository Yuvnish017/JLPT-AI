    "grammar": [
      {
        "pattern": "AはBより〜です",
        "meaning": "A is more ~ than B (comparison)",
        "example": "この荷物はあの荷物より重いです。(This luggage is heavier than that one.)"
      },
      {
        "pattern": "〜中 (じゅう / ちゅう)",
        "meaning": "Throughout ~; in the middle of doing ~",
        "example": "世界中を旅したいです。(I want to travel throughout the world.) / 授業中は静かにしてください。(Please be quiet during class.)"
      },
      {
        "pattern": "Verb て-form + ください",
        "meaning": "Please do ~ (polite request)",
        "example": "窓を開けてください。(Please open the window.)"
      },
      {
        "pattern": "Noun + が + 始まる / 終わる",
        "meaning": "Something begins / ends (intransitive — subject acts on itself)",
        "example": "授業が始まります。(The class is beginning.) / 映画が終わりました。(The movie ended.)"
      },
      {
        "pattern": "Noun + を + 始める / 終える",
        "meaning": "To start / finish something (transitive — subject acts on an object)",
        "example": "勉強を始めましょう。(Let's start studying.) / 仕事を終えました。(I finished the work.)"
      },
      {
        "pattern": "〜以上 / 以下 / 以内 / 以外",
        "meaning": "More than ~ / not exceeding ~ / within ~ / except ~",
        "example": "千円以上で買えます。(You can buy it for 1,000 yen or more.) / 土日以外は仕事があります。(I have work except on weekends.)"
      },
      {
        "pattern": "Verb dictionary form + ことができる",
        "meaning": "Can do ~ (potential expression)",
        "example": "ここで地図を見ることができます。(You can look at a map here.)"
      },
      {
        "pattern": "〜に注意してください",
        "meaning": "Please be careful about ~",
        "example": "発音に注意してください。(Please pay attention to pronunciation.)"
      }
    ],
