    "grammar": [
      {
        "pattern": "〜中 (じゅう)",
        "meaning": "Throughout ~, all over ~",
        "example": "兄は世界中を旅行しています。(My older brother is traveling throughout the world.)"
      },
      {
        "pattern": "Noun + で + おぼえましょう (グループで / ペアで)",
        "meaning": "Learn in groups / pairs — textbook instruction pattern",
        "example": "ペアでおぼえましょう：売る⟺買う。(Learn these as pairs: sell ⟺ buy.)"
      },
      {
        "pattern": "Verb (intransitive) ⟺ Verb (transitive) pairs",
        "meaning": "Japanese has paired intransitive and transitive verbs. The intransitive takes が; the transitive takes を.",
        "example": "ドアが開く（intransitive）⟺ ドアを開ける（transitive）。 / 仕事が始まる ⟺ 仕事を始める。"
      },
      {
        "pattern": "売る ⟺ 買う / 貸す ⟺ 借りる / 習う ⟺ 教える",
        "meaning": "Opposite-meaning verb pairs",
        "example": "この本を図書館で借りました。⟺ 友達にペンを貸してあげました。(I borrowed this book from the library. ⟺ I lent my friend a pen.)"
      },
      {
        "pattern": "〜に乗る / 〜を降りる",
        "meaning": "To get on ~ / to get off ~",
        "example": "特急に乗って、次の駅で降ります。(I'll ride the special express and get off at the next station.)"
      },
      {
        "pattern": "Verb て-form + みる",
        "meaning": "To try doing something",
        "example": "この薬を飲んでみてください。(Please try taking this medicine.)"
      },
      {
        "pattern": "〜前に / 〜あとで",
        "meaning": "Before doing ~ / after doing ~",
        "example": "寝る前に宿題をしなければなりません。(I have to do my homework before sleeping.)"
      },
      {
        "pattern": "Noun + が + 心配です / 安心しました",
        "meaning": "I'm worried about ~ / I feel relieved",
        "example": "試験の結果が心配です。(I'm worried about the exam results.) / 合格して安心しました。(I passed and felt relieved.)"
      }
    ],
