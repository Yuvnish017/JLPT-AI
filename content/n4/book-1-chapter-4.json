    "grammar": [
      {
        "pattern": "Verb (同音異義) — Same sound, different kanji and meaning",
        "meaning": "Several Japanese verbs share the same pronunciation but are written with different kanji and carry different meanings. Context and the particle used determine which is correct.",
        "example": "かぜを【引く】(catch a cold) vs ドアを【引く】(pull a door) vs ギターを【弾く】(play guitar) — all read ひく but written differently."
      },
      {
        "pattern": "〜が 空く / 〜が 込む",
        "meaning": "Something becomes empty/uncrowded (空く) vs something is crowded (込む). The subject takes が.",
        "example": "お腹が空きました。(I got hungry.) / 電車が込んでいます。(The train is crowded.)"
      },
      {
        "pattern": "Verb て-form + おく",
        "meaning": "To do something in advance, to leave something in a certain state",
        "example": "出かける前に、窓を閉めておきました。(Before going out, I closed the window ahead of time.)"
      },
      {
        "pattern": "〜てから / 〜あとで",
        "meaning": "After doing ~ (sequential action)",
        "example": "歯を磨いてから、寝ます。(After brushing my teeth, I go to sleep.) / ご飯を食べたあとで、薬を飲んでください。(Please take medicine after eating.)"
      },
      {
        "pattern": "Verb (〜に行く / 〜に来る) directional expressions",
        "meaning": "連れて行く (take a person), 持って行く (take a thing), 迎えに行く (go pick up), 送りに行く (go see off)",
        "example": "駅まで友達を迎えに行きます。(I will go pick up my friend at the station.) / 荷物を持って来てください。(Please bring the luggage.)"
      },
      {
        "pattern": "はじめは / はじめて / はじめに の違い",
        "meaning": "はじめは = at first (contrasts with later); はじめて = for the first time ever; はじめに = firstly (ordering steps)",
        "example": "はじめは難しかったですが、だんだん慣れました。(At first it was hard, but I gradually got used to it.) / きのう、はじめてさしみを食べました。(Yesterday I ate sashimi for the first time.)"
      },
      {
        "pattern": "おもう vs かんがえる vs おぼえる",
        "meaning": "思う = feel/think instinctively; 考える = think/consider deliberately; 覚える = memorize/learn",
        "example": "いいと思います。(I think it's good — gut feeling.) / よく考えましょう。(Let's think it over carefully.) / 新しい単語を覚えます。(I will memorize new vocabulary.)"
      },
      {
        "pattern": "Adjective antonym pairs (ペア)",
        "meaning": "Week 4 emphasizes opposite adjective pairs for descriptive precision.",
        "example": "濃い⟺薄い (strong⟺weak/light)、深い⟺浅い (deep⟺shallow)、硬い⟺柔らかい (hard⟺soft)、厳しい⟺優しい (strict⟺gentle)、にぎやかな⟺静かな (lively⟺quiet)"
      }
    ],
