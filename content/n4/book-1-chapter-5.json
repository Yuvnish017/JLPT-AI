    "grammar": [
      {
        "pattern": "Intransitive verb (が) ⟺ Transitive verb (を) — directional pairs",
        "meaning": "Many movement verbs come in intransitive/transitive pairs. The intransitive describes something happening on its own (subject + が); the transitive describes someone doing it to something (object + を).",
        "example": "ねだんが上がった。(Prices went up — intransitive.) / ねだんを上げた。(They raised the price — transitive.) / ねつが下がった ⟺ ねつを下げた。"
      },
      {
        "pattern": "〜が 減る ⟺ 〜が 増える",
        "meaning": "To decrease ⟺ to increase. Both are intransitive; the changing thing takes が.",
        "example": "さいきん、体重が増えました。(My weight has increased recently.) / 学生の数が減っています。(The number of students is decreasing.)"
      },
      {
        "pattern": "AからBを出す ⟺ AにBを入れる",
        "meaning": "To take B out of A ⟺ to put B into A",
        "example": "かばんからさいふを出しました。(I took my wallet out of my bag.) / せんたくきにせんざいを入れました。(I put detergent into the washing machine.)"
      },
      {
        "pattern": "〜中 (ちゅう) — during / currently doing",
        "meaning": "Attached to a noun to mean 'in the middle of ~' or 'currently doing ~'. Equivalent to 〜している.",
        "example": "食事中です。(= 食事をしています) (I'm in the middle of eating.) / 使用中のトイレ。(The toilet is in use.)"
      },
      {
        "pattern": "きっと / やっと / ずっと — adverb nuances",
        "meaning": "きっと = surely/probably (speaker's confident expectation); やっと = finally (after a long wait or effort); ずっと = throughout / all along / much more",
        "example": "よく勉強したから、きっと合格するでしょう。(You studied hard, so you'll surely pass.) / やっとバスが来た。(The bus finally came.) / 妹は朝からずっと勉強している。(My sister has been studying since morning.)"
      },
      {
        "pattern": "やっぱり — just as I thought / after all",
        "meaning": "Used when a result matches what was expected or when changing one's mind back to an original thought.",
        "example": "おいしそうだと思って食べたら、やっぱりおいしかった。(I thought it looked delicious, and sure enough it was.) / りんごにしようかな…あ、やっぱりケーキにしよう！(Should I get an apple… actually, I'll go with cake after all!)"
      },
      {
        "pattern": "Transitive verb (を) ⟺ Intransitive verb (が) — loss/discovery pairs",
        "meaning": "落とす⟺落ちる、壊す⟺壊れる、なくす⟺なくなる、見つける⟺見つかる。Transitive = someone does it ON something (を); intransitive = it happens BY ITSELF (が).",
        "example": "さいふを落とした。(I dropped my wallet.) / さいふが落ちた。(The wallet fell.) / スマホを壊した。(I broke my smartphone.) / スマホが壊れた。(The smartphone broke.)"
      },
      {
        "pattern": "できる — multiple meanings",
        "meaning": "できる has three key meanings that must be determined by context: (1) can do ~, (2) something is finished/ready, (3) a new place/thing has come into existence.",
        "example": "(1) 日本語ができます。(I can speak Japanese.) (2) ごはんができた。(Dinner is ready.) (3) 駅の前に新しい店ができた。(A new shop has opened in front of the station.)"
      }
    ],
