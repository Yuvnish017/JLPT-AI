  "grammar": [
    {
      "pattern": "Verb stem + ましょう",
      "meaning": "Let's do ~ (suggestion)",
      "example": "漢字を勉強しましょう。(Let's study kanji.)"
    },
    {
      "pattern": "Noun + を + 降りる",
      "meaning": "To get off (a vehicle)",
      "example": "バスを降りる。(Get off the bus.)"
    },
    {
      "pattern": "Noun + に + 通う",
      "meaning": "To commute to / attend (a place regularly)",
      "example": "バスで学校に通っています。(I commute to school by bus.)"
    },
    {
      "pattern": "Adjective い → Adjective く",
      "meaning": "Adverbial form of i-adjective",
      "example": "暗いところで本を読むと、目が悪くなりますよ。(If you read in a dark place, your eyes will get worse.)"
    },
    {
      "pattern": "Noun + が + 降る",
      "meaning": "Rain/snow falls",
      "example": "雨が降る。(It rains.)"
    },
    {
      "pattern": "～に 注意しましょう",
      "meaning": "Let's be careful about ~",
      "example": "発音に注意しましょう。(Let's be careful about pronunciation.)"
    },
    {
      "pattern": "Verb (て-form) + から",
      "meaning": "After doing ~, then …",
      "example": "考えてから、作文を書きます。(After thinking, I will write the composition.)"
    },
    {
      "pattern": "Adjective + ⟺ Antonym",
      "meaning": "Opposite adjectives (pair learning)",
      "example": "近い ⟺ 遠い、高い ⟺ 安い・低い (near ⟺ far, tall ⟺ cheap / low)"
    }
  ],
