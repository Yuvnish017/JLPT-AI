    "grammar": [
      {
        "pattern": "〜て います (ongoing action)",
        "meaning": "Expresses an action currently in progress. '(Someone) is doing ~.'",
        "example": "こうじょうで はたらいて います。— I am working at a factory."
      },
      {
        "pattern": "〜て います (ongoing state)",
        "meaning": "Expresses a resulting state that continues. Often used with verbs like すむ、しる、けっこんする.",
        "example": "日本に すんで います。— I live in Japan."
      },
      {
        "pattern": "〜が すきです / きらいです",
        "meaning": "Expresses liking or disliking something. が marks what you like/dislike.",
        "example": "わたしは からい たべものが きらいです。— I dislike spicy food."
      },
      {
        "pattern": "〜が わかります / しって います",
        "meaning": "Expresses understanding or knowing. わかります = understand; しって います = know (a fact/person).",
        "example": "この 人を しって います。— I know this person."
      },
      {
        "pattern": "あまり〜ない / ぜんぜん〜ない",
        "meaning": "Degree adverbs used with negative verbs. あまり = not very; ぜんぜん = not at all.",
        "example": "ドイツ語は ぜんぜん わかりません。— I don't understand German at all."
      },
      {
        "pattern": "もう〜ました / まだです",
        "meaning": "Expresses whether something has happened yet. もう + past = already done; まだです = not yet.",
        "example": "もう しました。↔ まだです。— Already done. ↔ Not yet."
      },
      {
        "pattern": "〜を あけます / しめます (他動詞 vs 自動詞)",
        "meaning": "Transitive verbs take を for the object (someone acts on it). Intransitive verbs use が (it happens by itself).",
        "example": "ドアを あけます。/ ドアが あきます。— (I) open the door. / The door opens."
      },
      {
        "pattern": "〜に すんで います",
        "meaning": "Expresses one's place of residence with the particle に.",
        "example": "東京に すんで います。— I live in Tokyo."
      },
      {
        "pattern": "〜で はたらいて います",
        "meaning": "Expresses the place of work using particle で.",
        "example": "かいしゃで はたらいて います。— I work at a company."
      },
      {
        "pattern": "わたしの〜 vs あなたの〜 (family terms)",
        "meaning": "Japanese uses different words for own family (humble) vs. others' family (polite). e.g. ちち vs おとうさん.",
        "example": "ちち は いしゃです。おとうさんは おいくつですか。— My father is a doctor. How old is your father?"
      }
    ],
