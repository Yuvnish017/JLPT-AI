    "grammar": [
      {
        "pattern": "とても / たいへん / すごく / ほんとうに (degree adverbs)",
        "meaning": "These adverbs intensify adjectives or verbs. とても and たいへん mean 'very/terribly'; すごく is the casual form; ほんとうに means 'truly/really'. 〜は たいへんです says something is difficult or tough.",
        "example": "日本語が とても 上手ですね。／ 日本語の べんきょうは たいへんです。"
      },
      {
        "pattern": "あまり〜ない / ぜんぜん〜ない (negative degree adverbs)",
        "meaning": "あまり means 'not very' and ぜんぜん means 'not at all' — both used with negative verb/adjective forms. あんまり is the casual variant of あまり.",
        "example": "今日は あまり さむく ありません。／ テストは ぜんぜん できませんでした。"
      },
      {
        "pattern": "まあまあ / ほとんど / だいたい / さっき / もうすぐ (miscellaneous adverbs)",
        "meaning": "まあまあ = so-so. ほとんど = mostly / hardly (with negatives). だいたい = generally/approximately. さっき = a moment ago. もうすぐ = very soon.",
        "example": "テストは まあまあ でした。／ 日本語は ほとんど 話せません。／ もうすぐ 12時です。"
      },
      {
        "pattern": "い-A く V / な-A に V (adverbial forms of adjectives)",
        "meaning": "い-adjectives change to adverb form by replacing い with く (e.g. 早い→早く). な-adjectives add に (e.g. しずかな→しずかに). These modify verbs to describe how an action is done.",
        "example": "早く かえりましょう。／ たいせつに つかいます。／ しずかに して ください。"
      },
      {
        "pattern": "〜く なります / 〜に なります (natural change — become ~)",
        "meaning": "なります expresses a natural change or development of state. い-adjectives use 〜く; な-adjectives and nouns use 〜に. Note: いい → よく なります.",
        "example": "日本語が 上手に なりました。／ 天気が よく なりました。／ べんりに なりました。"
      },
      {
        "pattern": "〜く します / 〜に します (intentional change — make ~ / decide on ~)",
        "meaning": "します expresses a deliberate change caused by the speaker. い-adjectives use 〜く; な-adjectives and nouns use 〜に. Also used when deciding on something (e.g. ラーメンに しましょう = Let's go with ramen).",
        "example": "テレビの おとを 小さく して ください。／ うるさいです。しずかに して ください。"
      },
      {
        "pattern": "〜とき (when ~)",
        "meaning": "とき connects a clause to describe when something happens. Use the plain form of the verb before とき. For current state use 〜ている とき; for actions not yet done, use dictionary form.",
        "example": "ひまな とき、何を して いますか。／ 本を 読む とき、めがねを かけます。／ 東京に 行った とき 買いました。"
      },
      {
        "pattern": "Vる 前に / N の 前に (before doing ~)",
        "meaning": "前に follows either a noun + の, or a verb in the dictionary form. It indicates the action/time before which something takes place. Note: always use dictionary form before 前に, NOT the past form.",
        "example": "じゅぎょうの 前に、よしゅうを しましょう。／ 日本に 来る 前に、日本語の べんきょうを しました。"
      },
      {
        "pattern": "Vた あとで / N の あとで (after doing ~)",
        "meaning": "あとで follows either a noun + の, or a verb in the past plain form (た-form). It indicates the action/time after which something takes place. Contrast with てから (Chapter 4), which is stricter about sequential order.",
        "example": "おふろに 入った あとで ビールを 飲みます。／ じゅぎょうの あとで 買いものを します。"
      },
      {
        "pattern": "Vに 行きます／来ます／かえります (go/come in order to ~)",
        "meaning": "に indicates the purpose of movement. Attach に to the verb stem (masu-stem) to express what you are going/coming to do.",
        "example": "としょかんへ 本を かえしに 行きました。／ ひまな ときは えいがを 見に 行きます。"
      },
      {
        "pattern": "A は B より〜 / A より B の ほうが〜 (comparison)",
        "meaning": "より marks the item being compared against (= 'than'). ほうが identifies the one that is 'more' of the quality. The two patterns are mirrors of each other.",
        "example": "父は 母より わかいです。／ わたしより おとうとの ほうが せが 高いです。"
      },
      {
        "pattern": "A と B と どちら(どっち)が〜 (which of two is more ~?)",
        "meaning": "Used to compare two items and ask/state which is more ~ . どちら is polite; どっち is casual. Answer with 〜の ほうが〜.",
        "example": "ペンと えんぴつと どっちを よく つかいますか。／ ぎゅうにくの ほうが 高いです。"
      },
      {
        "pattern": "〜のなかで〜がいちばん〜 (superlative — most ~ among ~)",
        "meaning": "Identifies the one item that is 'the most ~' within a group. The group is marked by の中で; the top item by が いちばん.",
        "example": "くだものの 中で りんごが いちばん すきです。／ 日本では ふじ山が いちばん 高い 山です。"
      },
      {
        "pattern": "〜たり、〜たり します (doing things like ~ and ~)",
        "meaning": "Used to give a non-exhaustive list of representative activities. Formed by adding り to the past plain form (た-form). The final verb is します (or して います for ongoing).",
        "example": "休みの 日は 友だちと 買いものに 行ったり、食事を したり します。"
      },
      {
        "pattern": "Vる こと / Vる の — nominalisation (verb as noun)",
        "meaning": "Adding こと or の to a verb's dictionary form turns the verb into a noun phrase. こと is formal; の is informal and used in speech. Use in patterns like 〜は〜ことです, 〜ことが できます, and 〜のは〜です.",
        "example": "わたしの しゅみは えいがを 見る ことです。／ かんじを 読む ことは できますが、書く ことは できません。"
      },
      {
        "pattern": "Vること が できます / 可能形 (can do ~ / potential form)",
        "meaning": "Ability is expressed either with Vる ことが できます (dictionary form + こと + が + できます) or with the potential verb form (書く→書ける, 話す→話せる, 食べる→食べられる, 来る→来られる, する→できる). Both are equally correct.",
        "example": "わたしは ロシア語を 話す ことが できます。／ 日本語は 少し 話せます。／ わたしは およげません。"
      }
    ],
