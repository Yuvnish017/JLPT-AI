    "grammar": [
      {
        "pattern": "い形容詞 の 活用 — い-adjective conjugation",
        "meaning": "い-adjectives change ending for tense and polarity: ~い (present positive) → ~くない (present negative) → ~かった (past positive) → ~くなかった (past negative). Special case: いい → よい → よくない → よかった → よくなかった.",
        "example": "おもしろいです → おもしろくないです → おもしろかったです → おもしろくなかったです"
      },
      {
        "pattern": "な形容詞 の 活用 — na-adjective conjugation",
        "meaning": "な-adjectives use では/じゃ ありません for negative and でした for past. Past negative: では/じゃ ありませんでした / じゃなかったです.",
        "example": "きれいです → きれいじゃないです → きれいでした → きれいじゃなかったです"
      },
      {
        "pattern": "あります vs います",
        "meaning": "あります expresses existence of inanimate objects (or possession). います expresses existence of people and animals. Both follow the pattern: [place] に [subject] が あります/います.",
        "example": "つくえの 上に ほんが あります。／ いすの 上に ねこが います。"
      },
      {
        "pattern": "〜の (pronoun replacement)",
        "meaning": "の can replace a noun already understood from context. It stands in for the noun after a possessive or descriptor.",
        "example": "A「この ペンは あなたのですか。」B「田中さんのです。わたしのは あおいのです。」"
      },
      {
        "pattern": "N は (topic marker — dual function)",
        "meaning": "は marks the topic of the sentence. It can ① indicate the topic, or ② express contrast or emphasis between two things.",
        "example": "① わたしは カナダから 来ました。② にくは 食べますが、さかなは 食べません。"
      },
      {
        "pattern": "疑問詞 + が (question word as subject)",
        "meaning": "When an interrogative word (だれ、なに、どれ etc.) is the subject of the sentence, it takes が, not は.",
        "example": "どれが 田中さんの コップですか。"
      },
      {
        "pattern": "N に (particle — place, time, recipient)",
        "meaning": "に marks ① a destination or location, ② a specific point in time, ③ the recipient of an action.",
        "example": "① 右に まがってください。② 月よう日に 来てください。③ 先生に 聞きます。"
      },
      {
        "pattern": "N で (particle — place of action, means, scope)",
        "meaning": "で marks ① the place where an action occurs, ② the method/tool used, ③ the scope or range.",
        "example": "① こうえんで あそびました。② 電車で 行きます。③ せかいで いちばん 長い 川は ナイル川です。"
      },
      {
        "pattern": "N から N まで (from ~ to ~)",
        "meaning": "から marks the starting point (place or time); まで marks the end point. Used together to express a range.",
        "example": "うちから 学校まで 1時間 かかります。／ テストは 15日から 18日までです。"
      },
      {
        "pattern": "N ごろ / N くらい／ぐらい / N だけ / N か N / N や N など",
        "meaning": "ごろ = around (time approximation). くらい/ぐらい = approximately (quantity/degree). だけ = only/just. か = or (between nouns). や〜など = things like ~ and ~.",
        "example": "7時ごろ 電話します。／ 1,000円ぐらい かかります。／ 休みは 日よう日だけです。／ コーヒーか こうちゃ、どちらが いいですか。／ 駅の 前には コンビニや ぎんこうなどが あります。"
      }
    ],
