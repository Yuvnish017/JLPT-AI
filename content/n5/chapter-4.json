    "grammar": [
      {
        "pattern": "疑問詞 + か / 疑問詞 + も〜ない / 疑問詞 + でも",
        "meaning": "Question words combine with か (some~), も+negative (no~/not any~), and でも (any~/every~) to form indefinite and universal pronouns.",
        "example": "なにか 食べましょう。(Let's eat something.) ／ なにも 食べませんでした。(I didn't eat anything.) ／ なんでも 食べます。(I eat anything.)"
      },
      {
        "pattern": "どうですか / いかがですか",
        "meaning": "Used to ask how something is, or to politely offer/suggest something. いかがですか is the more polite form of どうですか.",
        "example": "コーヒーは いかがですか。(Would you like some coffee?) ／ 旅行は どうでしたか。(How was the trip?)"
      },
      {
        "pattern": "い形容詞・な形容詞 の て形 (te-form of adjectives for listing)",
        "meaning": "い-adjectives use 〜くて to connect clauses. な-adjectives and nouns use 〜で. Used to list properties or actions in sequence.",
        "example": "安くて、おいしいです。(It's cheap and delicious.) ／ 先生は きれいで、やさしいです。(The teacher is pretty and kind.)"
      },
      {
        "pattern": "Vて形 (verb te-form) — sequential actions",
        "meaning": "The te-form connects verbs to describe actions done in sequence. It can also indicate manner or means of doing something.",
        "example": "おきて、あさごはんを 食べて、さんぽに 行きます。(I get up, eat breakfast, and go for a walk.)"
      },
      {
        "pattern": "〜てから (after doing ~)",
        "meaning": "Attaches to the te-form of a verb to indicate that the following action happens AFTER the first is completed.",
        "example": "手を あらってから ごはんを 食べましょう。(Let's eat after washing our hands.)"
      },
      {
        "pattern": "N が ほしいです / V たいです (want)",
        "meaning": "ほしいです expresses desire for a thing (noun + が). たいです attaches to the verb stem to express desire to do an action. Both conjugate like い-adjectives for past and negative.",
        "example": "じてんしゃが ほしいです。(I want a bicycle.) ／ ステーキが 食べたいです。(I want to eat steak.)"
      },
      {
        "pattern": "〜てください / 〜ないでください (requests)",
        "meaning": "てください asks someone to do something (please do ~). ないでください asks someone NOT to do something (please don't ~).",
        "example": "ちょっと まって ください。(Please wait a moment.) ／ ペンで 書かないで ください。(Please don't write with a pen.)"
      },
      {
        "pattern": "もらいます / くれます / あげます (giving and receiving)",
        "meaning": "もらいます = speaker receives from someone. くれます = someone gives to the speaker (or speaker's in-group). あげます = speaker/someone gives to another person. Direction of giving/receiving determines the verb.",
        "example": "友だちに 本を もらいました。(I received a book from my friend.) ／ 友だちが チョコレートを くれました。(My friend gave me chocolate.) ／ いもうとに スカートを あげます。(I will give my sister a skirt.)"
      },
      {
        "pattern": "〜ましょう / 〜ましょうか / 〜ませんか (invitation and suggestion)",
        "meaning": "ましょう = let's ~ (speaker proposes). ましょうか = shall we ~? / shall I ~? (softer proposal). ませんか = why don't we ~? (polite invitation).",
        "example": "いっしょに 行きましょう。(Let's go together.) ／ てつだいましょうか。(Shall I help?) ／ いっしょに えいがを 見ませんか。(Why don't we watch a movie together?)"
      },
      {
        "pattern": "〜から (because) / だから (therefore) / 〜けれど(も)・が・でも (but)",
        "meaning": "から attaches to a plain or polite verb/adjective to give a reason (because). だから means 'therefore/so' at the start of a clause. けれど(も)、が、でも all mean 'but/however' with varying formality (でも most casual, しかし most formal).",
        "example": "時間が ないから、いそぎましょう。(Let's hurry because there's no time.) ／ テストが あるからです。(It's because there's a test.) ／ べんきょうしたけれど、テストは できませんでした。(I studied, but I didn't do well on the test.)"
      },
      {
        "pattern": "修飾節 — noun modification with plain-form verb/adjective",
        "meaning": "In Japanese, modifying clauses come BEFORE the noun they modify, using the plain form. This works for verbs, い-adjectives, and な-adjectives (without な in plain form).",
        "example": "クラスで つかう 本です。(This is a book I use in class.) ／ 安くて おいしい レストランが あります。(There is a cheap and good restaurant.) ／ 田中さんが はたらいている 会社。(The company where Tanaka-san works.)"
      },
      {
        "pattern": "文末表現 — ね・ねえ / よ (sentence-final particles)",
        "meaning": "ね / ねえ seeks agreement or expresses shared feeling ('isn't it?', 'right?'). よ informs the listener of something or asserts with confidence ('I'm telling you', 'you know').",
        "example": "毎日 あついですね。(It's hot every day, isn't it.) ／ テストは あしたですよ。(The test is tomorrow, you know.)"
      }
    ],
